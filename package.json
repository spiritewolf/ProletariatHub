{
  "name": "proletariat-hub",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write \"{apps,packages}/**/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"{apps,packages}/**/src/**/*.{ts,tsx}\"",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "typecheck": "yarn workspaces foreach -Apt run typecheck",
    "check": "yarn format:check && yarn lint && yarn typecheck",
    "fix": "yarn format && yarn lint:fix",
    "start": "docker compose up --build",
    "stop": "docker compose down",
    "start:prod": "docker compose -f docker-compose.prod.yml up --build",
    "stop:prod": "docker compose -f docker-compose.prod.yml down",
    "dev": "concurrently -n api,web \"yarn dev:api\" \"yarn dev:web\"",
    "dev:api": "yarn workspace api dev",
    "dev:web": "yarn workspace web dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.1"
  }
}
