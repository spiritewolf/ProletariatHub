{
  "name": "proletariat-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "pnpm --filter @proletariat-hub/ui run typegen",
    "build": "node ./scripts/turbo-with-env.mjs build",
    "lint": "node ./scripts/turbo-with-env.mjs lint",
    "typecheck": "node ./scripts/turbo-with-env.mjs typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "node ./scripts/turbo-with-env.mjs db:generate",
    "db:migrate": "node ./scripts/turbo-with-env.mjs db:migrate",
    "db:seed": "node ./scripts/turbo-with-env.mjs db:seed",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:publish": "node ./scripts/turbo-with-env.mjs build --filter=@proletariat-hub/api --filter=@proletariat-hub/web --filter=@proletariat-hub/worker"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.19.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.7.4",
    "turbo": "^2.7.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
