# Copy to `.env` at the repository root.
# SQLite path. Relative paths are resolved from the monorepo root (not process cwd).
DATABASE_URL=file:./data/app.db

# Set to "true" behind HTTPS so session cookies get the Secure flag.
# COOKIE_SECURE=true

# Strong random passphrase for AES-256-GCM encryption of saved passwords (hub credentials).
# If unset, a dev-only default is used — set this in any shared or production deploy.
# CREDENTIALS_ENCRYPTION_KEY=
