{
  "name": "@proletariat-hub/database",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "postinstall": "prisma generate --no-hints",
    "db:generate": "prisma generate --no-hints",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "build": "tsx ./scripts/build.mts",
    "lint": "eslint .",
    "typecheck": "tsx ./scripts/typecheck.mts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@proletariat-hub/types": "workspace:*"
  },
  "devDependencies": {
    "@proletariat-hub/typescript-config": "workspace:*",
    "bcryptjs": "^3.0.2",
    "eslint": "^9.39.1",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
