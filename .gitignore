# Dependencies (never commit install trees or local store mirrors)
node_modules/
.pnpm-store/

# Build outputs (TypeScript, Vite, bundlers, etc.)
dist/
build/
out/
*.tsbuildinfo

# Environment & secrets (templates like .env.example stay tracked)
.env
.env.*
!.env.example
!.env.template
!.env.sample
*.pem
*.p12
*.key
.turbo/

# Tests & E2E (coverage, Playwright artifacts)
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/
blob-report/

# Tooling caches (ESLint, bundlers, generic caches)
.eslintcache
.cache/
.parcel-cache/
.vite/
**/.vite/

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local / embedded databases (Prisma SQLite, local dev dumps)
*.db
*.db-journal
*.db-wal
*.db-shm
data/

# Operating system junk
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# IDEs & editors
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/*
!.vscode/extensions.json

# Deployment previews (hosting CLIs)
.vercel/
.netlify/


docker-compose.override.yml

.compose-dev-build-lock/
.database-build.lock

# AI / coding assistants (if you're going to use them don't commit them)
.cursor/
.cursorignore
.claude/
.aider*
.continue/

docs/setup-guide.md